# =============================================================================
# Ingestion service — environment variables
# Copy this file to `.env` and fill in the values.
# On Railway, set the same keys in the service's "Variables" tab.
# =============================================================================


# -----------------------------------------------------------------------------
# MQTT broker
# -----------------------------------------------------------------------------

# Hostname only — no scheme, no port.
#   e.g. broker.hivemq.com   |   mosquitto.railway.internal   |   1.2.3.4
MQTT_HOST=

# 1883 = plain TCP   |   8883 = TLS
MQTT_PORT=1883

# true if the broker requires TLS (usually paired with port 8883)
MQTT_USE_TLS=false

# Leave blank for anonymous brokers
MQTT_USERNAME=
MQTT_PASSWORD=

# Identifier this client registers with the broker. Must be unique per
# concurrent connection. Anything stable works.
MQTT_CLIENT_ID=buxton-ingestion

# Topic pattern to subscribe to. `#` is a multi-level wildcard.
#   e.g. sensors/#   |   buxton/+/temperature   |   #
MQTT_TOPIC=sensors/#

# 0 = at most once   |   1 = at least once   |   2 = exactly once
MQTT_QOS=1


# -----------------------------------------------------------------------------
# InfluxDB v2
# -----------------------------------------------------------------------------

# Full URL including scheme and port.
#   e.g. https://us-east-1-1.aws.cloud2.influxdata.com
#        http://influxdb.railway.internal:8086
INFLUXDB_URL=

# API token with write access to the bucket below.
INFLUXDB_TOKEN=

# Organization name (InfluxDB Cloud) or org id.
INFLUXDB_ORG=

# Bucket the data will be written to. Create it in the InfluxDB UI first.
INFLUXDB_BUCKET=

# Optional — defaults to "ns" if blank. One of: ns, us, ms, s
INFLUXDB_PRECISION=ns


# -----------------------------------------------------------------------------
# Service
# -----------------------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
